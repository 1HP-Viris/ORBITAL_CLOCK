        # Calculates the staggered diagonal offset (2mm) against the faceplate.
        current_cycle_pos = calculate_staggered_offset(current_cycle_pos)
        
        # STEP 3: Verify "Stayed Connected" Status
        check_terminal_collapse(current_cycle_pos)
        
        # STEP 4: Update Radar Pings (Silver/Gold/Diamond Shift)
        # Triggers the aesthetic vector change on the Nadir Dial.
        signal_data_to_radar(current_cycle_pos)

def calculate_staggered_offset(previous_position):
    """
    Simulates the diagonal 'Catty' movement of the backplate.
    Utilizes an asymmetrical 4.5° staggered rotation.
    """
    STAGGERED_TICKS = 4.5 # Degrees per systemic pulse
    new_pos = (previous_position + STAGGERED_TICKS) % 360.0
    
    # Check for Eclipsing/White-Wash condition
    if math.isclose(new_pos % 30.0, 0, abs_tol=0.1):
        print(f"White-Wash Bloom triggered at position: {new_pos}")
        
    return new_pos

def check_terminal_collapse(position):
    """
    Monitors for the completion of the final 360° orbit (15-month reset).
    """
    if math.isclose(position, 0.0, abs_tol=0.1):
        print("--- DEUS RESET DETECTED ---")
        trigger_new_deus_collective()

